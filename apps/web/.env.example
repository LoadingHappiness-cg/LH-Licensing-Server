# External web origin. Use the VM/preprod host, not localhost.
SITE_URL=http://192.168.27.3:3000

# API base URL must be explicit so the UI never falls back to localhost.
API_BASE_URL=http://192.168.27.3:3001/api/v1

NEXTAUTH_SECRET=replace_with_a_long_random_secret

ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=replace_with_entra_client_secret
ENTRA_ADMIN_GROUP_ID=00000000-0000-0000-0000-000000000000

# Optional override if you need the callback URL to differ from SITE_URL.
# NEXTAUTH_URL=
